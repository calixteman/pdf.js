+    const len = outlines.length;
+    let total = 1 + 1 + 1 + len;
+    const header = new Uint16Array(total);
+    header[1] = contour ? 0 : 1;
+    header[2] = len;
+    let offset = 3;
+    for (const { length } of outlines) {
+      header[offset++] = length;
+      total += length;
